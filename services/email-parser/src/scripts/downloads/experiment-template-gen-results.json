  {
    "senderId": "swiggy",
    "senderName": "Swiggy",
    "emailsFetched": 15,
    "template": {
      "merchantName": "Swiggy",
      "rules": {
        "date": {
          "selector": "div.order-id p:contains('Order placed at') > strong",
          "regex": "(.+)",
          "transform": "string"
        },
        "amount": {
          "selector": "tr.grand-total > td[style*='padding-right']",
          "regex": "₹\\s?([\\d,]+\\.?\\d*)",
          "transform": "currency"
        },
        "orderId": {
          "selector": "div.order-id h5",
          "regex": "(\\d+)",
          "transform": "string"
        },
        "paymentMethod": {
          "selector": "tr:has(td:contains('Paid Via')) > td:last-child",
          "regex": "₹\\s?([\\d,]+\\.?\\d*)|([\\w ]+)",
          "transform": "string"
        }
      },
      "lineItems": {
        "containerSelector": "div.order-content table tbody",
        "itemSelector": "tr:not(.grand-total):not(:has(td:contains('Item Total'))):not(:has(td:contains('Discount Applied'))):not(:has(td:contains('Packaging'))):not(:has(td:contains('Platform Fee'))):not(:has(td:contains('Taxes'))):not(:has(td:contains('Delivery Fee'))):not(:has(td:contains('Paid Via')))",
        "nameRule": {
          "selector": "td.small",
          "regex": null
        },
        "priceRule": {
          "selector": "td:last-child",
          "regex": "₹\\s?([\\d,]+\\.?\\d*)"
        },
        "quantityRule": {
          "selector": "td:nth-child(2)",
          "regex": null
        }
      }
    },
    "templateGenCost": 0.0072208,
    "templateGenMs": 9209,
